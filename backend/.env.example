
# Configuración de Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
SUPABASE_KEY=tu-anon-key-aqui (opcional si usas Service Role Key)

# JWT Secret para tokens
JWT_SECRET=tu-jwt-secreto-aqui

# Contraseña predeterminada para restablecimiento de contraseñas
DEFAULT_RESET_PASSWORD=Pass123
